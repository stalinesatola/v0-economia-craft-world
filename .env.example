# Craft World Economy - Environment Variables
# Copy this file to .env and fill in your values

# Superadmin password (change this!)
SUPERADMIN_PASSWORD=your_secure_password_here

# Database URL (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxx-xxx-xxx-xxxx.neon.tech/gestem_soft?sslmode=require

# GeckoTerminal API (optional - public API)
GECKO_API_URL=https://api.geckoterminal.com/api/v2

# OpenSea API Key (get from https://docs.opensea.io/api/api-keys)
OPENSEA_API_KEY=015ce5f1adf34f0fa4d0049bee632f4d

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# X/Twitter API Credentials (for auto-posting)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Ronin Network
RONIN_NETWORK=ronin